{
  "manifest_version": 3,
  "name": "nJudge Bridge",
  "version": "1.0.0",
  "description": "Bridge between nJudge and Online Judges (Codeforces/AtCoder)",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://atcoder.jp/*",
    "http://127.0.0.1:54321/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
