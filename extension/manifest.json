{
  "manifest_version": 3,
  "name": "nJudge Bridge",
  "version": "1.0.0",
  "description": "Bridge between nJudge and Online Judges (Codeforces/AtCoder)",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://atcoder.jp/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
