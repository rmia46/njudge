{
  "manifest_version": 3,
  "name": "nJudge Bridge (Firefox)",
  "version": "1.0.0",
  "description": "Bridge between nJudge and Online Judges (Codeforces/AtCoder)",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://atcoder.jp/*",
    "http://127.0.0.1:54321/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bridge@njudge.app"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
